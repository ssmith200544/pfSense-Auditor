		<group>
			<name>admins</name>
			<description>System Administrators</description>
			<scope>system</scope>
			<gid>1999</gid>
			<member>0</member>
			<member>2000</member>
			<member>2001</member>
			<priv>page-all</priv>
		</group>
	</system>
	<interfaces>
		<wan>
			<if>em0</if>
			<descr>WAN</descr>
			<enable></enable>
			<ipaddr>dhcp</ipaddr>
			<ipaddrv6>dhcp6</ipaddrv6>
			<blockpriv></blockpriv>
			<blockbogons></blockbogons>
		</wan>
		<lan>
			<if>em1</if>
			<descr>LAN</descr>
			<enable></enable>
			<ipaddr>192.168.1.1</ipaddr>
			<subnet>24</subnet>
		</lan>
		<opt1>
			<if>em2</if>
			<descr>DMZ</descr>
			<enable></enable>
			<ipaddr>192.168.10.1</ipaddr>
			<subnet>24</subnet>
		</opt1>
		<opt2>
			<if>em3</if>
			<descr>MGMT</descr>
			<enable></enable>
			<ipaddr>192.168.99.1</ipaddr>
			<subnet>24</subnet>
		</opt2>
	</interfaces>
	<aliases>
		<alias>
			<name>InternalNets</name>
			<type>network</type>
			<address>10.0.0.0/8 192.168.0.0/16 172.16.0.0/12</address>
			<descr>RFC1918 internal networks</descr>
		</alias>
		<alias>
			<name>AdminWorkstations</name>
			<type>host</type>
			<address>192.168.99.10 192.168.99.11</address>
			<descr>Admin laptops for MGMT access</descr>
		</alias>
		<alias>
			<name>LegacyServers</name>
			<type>host</type>
			<address>192.168.10.50 192.168.10.51</address>
			<descr>Old DMZ servers - unused, kept for reference</descr>
		</alias>
		<alias>
			<name>WebPorts</name>
			<type>port</type>
			<address>80 443</address>
			<descr>HTTP/HTTPS</descr>
		</alias>
	</aliases>
	<filter>
		<rule>
			<id></id>
			<tracker>1700000001</tracker>
			<type>pass</type>
			<interface>lan</interface>
			<ipprotocol>inet</ipprotocol>
			<tag></tag>
			<tagged></tagged>
			<source>
				<any></any>
			</source>
			<destination>
				<any></any>
			</destination>
			<descr>Default allow LAN to any rule</descr>
			<log></log>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000002</tracker>
			<type>pass</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<any></any>
			</source>
			<destination>
				<address>InternalNets</address>
			</destination>
			<descr></descr>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000003</tracker>
			<type>pass</type>
			<interface>wan</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<any></any>
			</source>
			<destination>
				<network>(self)</network>
				<port>443</port>
			</destination>
			<descr>WAN HTTPS to firewall - DANGEROUS</descr>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000004</tracker>
			<type>pass</type>
			<interface>opt2</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<address>AdminWorkstations</address>
			</source>
			<destination>
				<any></any>
			</destination>
			<descr>MGMT admin workstations to any</descr>
			<log></log>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000005</tracker>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<any></any>
			</source>
			<destination>
				<address>InternalNets</address>
			</destination>
			<descr>Block DMZ to internal nets</descr>
			<disabled></disabled>
			<log></log>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000006</tracker>
			<type>pass</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<any></any>
			</source>
			<destination>
				<network>opt1</network>
				<port>WebPorts</port>
			</destination>
			<descr>Allow web traffic to DMZ servers</descr>
		</rule>
	</filter>
	<nat>
		<outbound>
			<mode>automatic</mode>
		</outbound>
		<rule>
			<source>
				<any></any>
			</source>
			<destination>
				<network>wanip</network>
				<port>22</port>
			</destination>
			<target>192.168.10.50</target>
			<local-port>22</local-port>
			<interface>wan</interface>
			<protocol>tcp</protocol>
			<descr>SSH to DMZ server (legacy)</descr>
		</rule>
		<rule>
			<source>
				<any></any>
			</source>
			<destination>
				<network>wanip</network>
				<port>3389</port>
			</destination>
			<target>192.168.1.20</target>
			<local-port>3389</local-port>
			<interface>wan</interface>
			<protocol>tcp</protocol>
			<descr>RDP to internal workstation - DANGEROUS</descr>
		</rule>
		<rule>
			<source>
				<any></any>
			</source>
			<destination>
				<network>wanip</network>
				<port>WebPorts</port>
			</destination>
			<target>192.168.10.51</target>
			<local-port>WebPorts</local-port>
			<interface>wan</interface>
			<protocol>tcp</protocol>
			<descr>HTTPS to DMZ web server</descr>
		</rule>
	</nat>
	<ipsec>
		<phase1>
			<ikeid>1</ikeid>
			<iketype>ikev1</iketype>
			<mode>aggressive</mode>
			<descr>Legacy site-to-site to remote office</descr>
			<encryption>
				<item>
					<encryption-algorithm>
						<name>3des</name>
					</encryption-algorithm>
					<hash-algorithm>md5</hash-algorithm>
					<dhgroup>2</dhgroup>
				</item>
			</encryption>
			<pre-shared-key>changeme123</pre-shared-key>
		</phase1>
		<phase1>
			<ikeid>2</ikeid>
			<iketype>ikev2</iketype>
			<descr>Modern tunnel to AWS</descr>
			<encryption>
				<item>
					<encryption-algorithm>
						<name>aes</name>
						<keylen>256</keylen>
					</encryption-algorithm>
					<hash-algorithm>sha256</hash-algorithm>
					<dhgroup>14</dhgroup>
				</item>
			</encryption>
		</phase1>
		<phase2>
			<ikeid>1</ikeid>
			<descr>Phase 2 for legacy tunnel</descr>
			<encryption-algorithm-option>
				<name>3des</name>
			</encryption-algorithm-option>
			<hash-algorithm-option>md5</hash-algorithm-option>
			<pfsgroup>0</pfsgroup>
		</phase2>
		<phase2>
			<ikeid>2</ikeid>
			<descr>Phase 2 for AWS tunnel</descr>
			<encryption-algorithm-option>
				<name>aes</name>
				<keylen>256</keylen>
			</encryption-algorithm-option>
			<hash-algorithm-option>sha256</hash-algorithm-option>
			<pfsgroup>14</pfsgroup>
		</phase2>
	</ipsec>
