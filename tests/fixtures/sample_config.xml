			<uid>0</uid>
			<expires></expires>
			<authorizedkeys></authorizedkeys>
			<ipsecpsk></ipsecpsk>
		</user>
		<user>
			<name>scott</name>
			<descr>Scott Smith</descr>
			<scope>user</scope>
			<groupname>admins</groupname>
			<bcrypt-hash>$2b$10$ANOTHEREXAMPLEHASHVALUENOTAREALONE</bcrypt-hash>
			<uid>2000</uid>
			<otp_seed>EXAMPLEBASE32OTPSEED</otp_seed>
		</user>
		<user>
			<name>contractor</name>
			<descr>External Contractor (project ended 2024)</descr>
