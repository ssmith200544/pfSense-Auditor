<?xml version="1.0"?>
<pfsense>
	<version>23.5</version>
	<lastchange>1701234567</lastchange>
	<system>
		<optimization>normal</optimization>
		<hostname>pfsense-lab</hostname>
		<domain>example.local</domain>
		<dnsserver>1.1.1.1</dnsserver>
		<dnsserver>8.8.8.8</dnsserver>
		<timeservers>0.pool.ntp.org</timeservers>
		<timezone>America/Chicago</timezone>
		<webgui>
			<protocol>http</protocol>
			<port></port>
			<max_procs>2</max_procs>
		</webgui>
		<ssh>
			<enable></enable>
			<port>22</port>
		</ssh>
		<user>
			<name>admin</name>
			<descr>System Administrator</descr>
			<scope>system</scope>
			<groupname>admins</groupname>
			<bcrypt-hash>$2b$10$EXAMPLEHASHVALUEFORTESTINGONLYNOTREAL</bcrypt-hash>
			<uid>0</uid>
			<expires></expires>
			<authorizedkeys></authorizedkeys>
			<ipsecpsk></ipsecpsk>
		</user>
		<user>
			<name>scott</name>
			<descr>Scott Smith</descr>
			<scope>user</scope>
			<groupname>admins</groupname>
			<bcrypt-hash>$2b$10$ANOTHEREXAMPLEHASHVALUENOTAREALONE</bcrypt-hash>
			<uid>2000</uid>
		</user>
		<group>
			<name>admins</name>
			<description>System Administrators</description>
			<scope>system</scope>
			<gid>1999</gid>
			<member>0</member>
			<member>2000</member>
			<priv>page-all</priv>
		</group>
	</system>
	<interfaces>
		<wan>
			<if>em0</if>
			<descr>WAN</descr>
			<enable></enable>
			<ipaddr>dhcp</ipaddr>
			<ipaddrv6>dhcp6</ipaddrv6>
			<blockpriv></blockpriv>
			<blockbogons></blockbogons>
		</wan>
		<lan>
			<if>em1</if>
			<descr>LAN</descr>
			<enable></enable>
			<ipaddr>192.168.1.1</ipaddr>
			<subnet>24</subnet>
		</lan>
		<opt1>
			<if>em2</if>
			<descr>DMZ</descr>
			<enable></enable>
			<ipaddr>192.168.10.1</ipaddr>
			<subnet>24</subnet>
		</opt1>
		<opt2>
			<if>em3</if>
			<descr>MGMT</descr>
			<enable></enable>
			<ipaddr>192.168.99.1</ipaddr>
			<subnet>24</subnet>
		</opt2>
	</interfaces>
	<aliases>
		<alias>
			<name>InternalNets</name>
			<type>network</type>
			<address>10.0.0.0/8 192.168.0.0/16 172.16.0.0/12</address>
			<descr>RFC1918 internal networks</descr>
		</alias>
		<alias>
			<name>AdminWorkstations</name>
			<type>host</type>
			<address>192.168.99.10 192.168.99.11</address>
			<descr>Admin laptops for MGMT access</descr>
		</alias>
		<alias>
			<name>LegacyServers</name>
			<type>host</type>
			<address>192.168.10.50 192.168.10.51</address>
			<descr>Old DMZ servers - unused, kept for reference</descr>
		</alias>
		<alias>
			<name>WebPorts</name>
			<type>port</type>
			<address>80 443</address>
			<descr>HTTP/HTTPS</descr>
		</alias>
	</aliases>
	<filter>
		<rule>
			<id></id>
			<tracker>1700000001</tracker>
			<type>pass</type>
			<interface>lan</interface>
			<ipprotocol>inet</ipprotocol>
			<tag></tag>
			<tagged></tagged>
			<source>
				<any></any>
			</source>
			<destination>
				<any></any>
			</destination>
			<descr>Default allow LAN to any rule</descr>
			<log></log>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000002</tracker>
			<type>pass</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<any></any>
			</source>
			<destination>
				<address>InternalNets</address>
			</destination>
			<descr></descr>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000003</tracker>
			<type>pass</type>
			<interface>wan</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<any></any>
			</source>
			<destination>
				<network>(self)</network>
				<port>443</port>
			</destination>
			<descr>WAN HTTPS to firewall - DANGEROUS</descr>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000004</tracker>
			<type>pass</type>
			<interface>opt2</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<address>AdminWorkstations</address>
			</source>
			<destination>
				<any></any>
			</destination>
			<descr>MGMT admin workstations to any</descr>
			<log></log>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000005</tracker>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<any></any>
			</source>
			<destination>
				<address>InternalNets</address>
			</destination>
			<descr>Block DMZ to internal nets</descr>
			<disabled></disabled>
			<log></log>
		</rule>
		<rule>
			<id></id>
			<tracker>1700000006</tracker>
			<type>pass</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<any></any>
			</source>
			<destination>
				<network>opt1</network>
				<port>WebPorts</port>
			</destination>
			<descr>Allow web traffic to DMZ servers</descr>
		</rule>
	</filter>
	<nat>
		<outbound>
			<mode>automatic</mode>
		</outbound>
	</nat>
	<snmpd>
		<syslocation></syslocation>
		<syscontact></syscontact>
		<rocommunity>public</rocommunity>
		<enable></enable>
		<bindip>all</bindip>
		<pollport>161</pollport>
	</snmpd>
	<syslog>
		<nentries>50</nentries>
		<logfilesize>511488</logfilesize>
	</syslog>
	<dhcpd>
		<lan>
			<enable></enable>
			<range>
				<from>192.168.1.100</from>
				<to>192.168.1.199</to>
			</range>
		</lan>
	</dhcpd>
</pfsense>
